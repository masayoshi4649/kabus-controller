[SYSTEM]
# サーバーのポート番号
Port = 8080

[KABUSTATION]
# KabuStation の API パスワード
APIPW = "password"

# KabuStation の実行ファイルパス(ダブルクォート禁止/シングルクォートを使用)
PATH = 'C:\Users\taro\AppData\Local\kabuStation\KabuS.exe'

# KabuStation の ログインボタンを押すまでの待機時間(秒)
WaitSecond = 5

[TRADE]
# KabuS REST API の定期取得間隔(ミリ秒)。0 以下ならバックグラウンドポーリングを無効化します。
POLLING_INTERVAL_MILLISEC = 1000
